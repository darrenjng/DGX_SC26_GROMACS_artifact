integrator               = md
nsteps                   = 2000
dt                       = 0.002

cutoff-scheme            = Verlet
nstlist                  = 10
rlist                    = 0.9
coulombtype              = PME
rcoulomb                 = 0.9
vdwtype                  = Cut-off
rvdw                     = 0.9
DispCorr                 = EnerPres

constraints              = h-bonds
constraint-algorithm     = LINCS
lincs-order              = 4

nstxout-compressed       = 0
nstxout                  = 0
nstvout                  = 0
nstfout                  = 0
nstenergy                = 100
nstlog                   = 100

comm-mode                = Linear
nstcomm                  = 100

pcoupl                   = no
tcoupl                   = V-rescale
tc-grps                  = System
tau-t                    = 1.0
ref-t                    = 300

gen-vel                  = yes
gen-temp                 = 300
gen-seed                 = 173529

pbc                      = xyz
